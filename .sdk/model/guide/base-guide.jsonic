# Guide

guide: {
  metrics: count: entity: 2
  metrics: count: path: 2
  metrics: count: method: 2

  entity: all: {
    path: "/historical/all": {
      op: load: method: *GET
    }
  }

  entity: historical: {
    path: "/historical/{country}": {
      rename: param: "country": *"id"
      op: load: method: *GET
    }
  }

}